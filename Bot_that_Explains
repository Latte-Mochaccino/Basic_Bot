from discord.ext import commands
import discord
import random

intents = discord.Intents.default()
intents.message_content = True

#$
bot = commands.Bot(command_prefix='$', intents=intents)

@bot.event
async def encendido():

    print(f'Tu bot {bot.user} esta en linea')

@bot.command(description='Envía un mensaje de saludo')
async def saludo(ctx):

    await ctx.send('Hola, qué tal?')


@bot.command(description='Hace una decisión entre varias opciones')
async def choose(ctx, *choices: str):
    """Chooses between multiple choices."""
    await ctx.send(f'El bot piensa que esta es la mejor opción: {random.choice(choices)}')


@bot.command(description='Lanza un dado en formato NdN')
async def roll(ctx, dice: str):
    """Gira un dado en formato NdN."""
    try:
        rolls, limit = map(int, dice.split('d'))
    except Exception:
        await ctx.send('¡Formato de dado inválido! Use NdN, por ejemplo 2d6.')
        return

    result = ', '.join(str(random.randint(1, limit)) for r in range(rolls))
    await ctx.send(result)


@bot.command(description='Envía un mensaje de despedida')
async def despedida (ctx, *, mensaje:str):

    #novemo

    mensaje = mensaje.lower()

    if "chao" in mensaje:

        await ctx.send('Chao se me cuida')
    
    elif "bye" in mensaje:

        await ctx.send('Goodbye')

    elif "novemo" in mensaje:

        await ctx.send('nosrevimos')

@bot.command(description='Explica la función de los comandos del bot')
async def explain(ctx):
    await ctx.send('Aquí tienes una lista de los comandos disponibles:')
    for command in bot.commands:
        await ctx.send(f'**{command.name}**: {command.description}')

